{
  "name": "bedrock-kms-module-key-storage-test",
  "version": "0.0.1-0",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "node --preserve-symlinks test.js test",
    "coverage": "cross-env NODE_ENV=test c8 npm test",
    "coverage-ci": "cross-env NODE_ENV=test c8 --reporter=lcovonly --reporter=text-summary --reporter=text npm test",
    "coverage-report": "c8 report"
  },
  "dependencies": {
    "@bedrock/core": "^6.3.0",
    "@bedrock/kms-module-key-storage": "file:..",
    "@bedrock/mongodb": "^11.0.1",
    "@bedrock/record-cipher": "^1.1.0",
    "@bedrock/test": "^8.2.0",
    "bnid": "^3.0.0",
    "c8": "^10.1.3",
    "cross-env": "^7.0.3"
  },
  "c8": {
    "excludeNodeModules": false,
    "include": [
      "node_modules/@bedrock/kms-module-key-storage/**"
    ],
    "exclude": [
      "node_modules/@bedrock/kms-module-key-storage/node_modules/**"
    ],
    "reporter": [
      "lcov",
      "text-summary",
      "text"
    ]
  }
}
